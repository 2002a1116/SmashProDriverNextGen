{
  "name": "smashpro_webdriver_nxtgen",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "pc": "gh-pages-clean",
    "post": "gh-pages -d dist",
    "clean": "docker image rm driver_frontend",
    "pack:build": "npm run build && npm run pack",
    "pack": "docker build -t driver_frontend . && docker save -o frontend.tar driver_frontend",
    "upload": "dockerx build -t driver_frontend .",
    "update": "npm run deploy && npm run upload"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "default-passive-events": "^4.0.0",
    "denque": "^2.1.0",
    "lodash": "^4.18.1",
    "marked": "^17.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11.2.8",
    "vuedraggable": "^4.1.0",
    "vuex": "^4.1.0",
    "y18n": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "gh-pages": "^6.3.0",
    "naive-ui": "^2.41.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.4"
  }
}
